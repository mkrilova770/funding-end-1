# SQLite по умолчанию (работает без Docker). Для PostgreSQL замените provider в prisma/schema.prisma и URL.
DATABASE_URL=file:./prisma/dev.db

# Интервал синка в worker (мс)
SYNC_INTERVAL_MS=45000

# Параллельные запросы истории на одну биржу (ограничение нагрузки)
SYNC_HISTORY_CONCURRENCY=6

# Дайджест в Telegram: токены с max спредом по фандингу > 0,25% (по всем биржам из приложения)
# Токен бота: @BotFather → TELEGRAM_BOT_TOKEN
# chat_id: напишите боту /start, затем https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Включение и слоты по МСК теперь в БД (кнопка «Telegram» на сайте). Переменная ниже — только для первого создания строки в БД.
TELEGRAM_SPREAD_DIGEST_ENABLED=0
# Если задано — сохранение настроек на сайте только с заголовком Authorization: Bearer <секрет>
TELEGRAM_DIGEST_UI_SECRET=

# --- Railway: файл .env.railway в корне — для импорта в Variables (RAW / Suggested). Подробно: RAILWAY.md ---
